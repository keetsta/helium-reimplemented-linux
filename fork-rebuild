#!/usr/bin/env bash
#
# fork-rebuild — fast incremental rebuild of the Helium fork for Linux.
#
# Reuses the Chromium source tree, applied patches and GN configuration that
# fork-build already prepared in build/src. It just recompiles the changed
# targets with ninja and repackages tar.xz + AppImage. It does NOT re-download
# Chromium and does NOT wipe out/.
#
# Use this after fork-build has succeeded once and you've changed patches /
# resources / source and want a quick turnaround. If the prepared tree doesn't
# exist yet, it tells you to run ./fork-build.
#
# Usage:
#   ./fork-rebuild
set -euo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
_src="$_self/build/src"
_out="$_src/out/Default"

if [ ! -d "$_src" ] || [ ! -f "$_out/args.gn" ]; then
  echo "error: no prepared build tree found at:" >&2
  echo "    $_out/args.gn" >&2
  echo "Run ./fork-build first to set up and build the source tree." >&2
  exit 1
fi

echo "==> fork-rebuild: incremental compile + repackage"
echo "    src : $_src"

# Log everything to build/logs/ (inside the folder) while still showing it live.
_log_dir="$_self/build/logs"
mkdir -p "$_log_dir"
_log_file="$_log_dir/fork-rebuild-$(date +%Y%m%d-%H%M%S).log"
ln -sf "$(basename "$_log_file")" "$_log_dir/latest.log"
echo "    log : $_log_file"
echo

# pipefail (set above) makes a failing step's status survive the tee pipe.
{
  cd "$_src"

  # Regenerate build files in case GN args / BUILD.gn changed, then compile.
  # gn was bootstrapped into out/Default by fork-build.
  ./out/Default/gn gen out/Default --fail-on-unused-args
  ninja -C out/Default chrome chromedriver

  # Repackage into tar.xz + AppImage (MAKE_DEB=1 also makes a .deb).
  cd "$_self"
  ./scripts/package.sh
} 2>&1 | tee "$_log_file"

echo
echo "==> done. Artifacts in: $_self/build/release/"
